generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Employee {
  id                 String          @id @default(auto()) @map("_id") @db.ObjectId
  fullName           String
  email              String          @unique
  phone              String?
  department         String?
  position           String?
  role               String          @default("employee")
  passwordHash       String
  leaveBalance       Int             @default(18)
  mustChangePassword Boolean         @default(false)
  status             String          @default("active")
  deletedAt          DateTime?
  createdAt          DateTime        @default(now())

  attendance         Attendance[]
  leaveRequests      LeaveRequest[]
  loginHistory       LoginHistory[]
  suspiciousLogs     SuspiciousLog[]
}

model Attendance {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  employeeId         String    @db.ObjectId
  date               DateTime
  checkIn            DateTime?
  checkOut           DateTime?
  hours              Float?
  status             String    @default("present")
  latitude           Float?
  longitude          Float?
  ipAddress          String?
  device             String?
  distanceFromOffice Float?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())

  employee           Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
}

model LeaveRequest {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  employeeId String    @db.ObjectId
  startDate  DateTime
  endDate    DateTime
  days       Int       @default(1)
  reason     String
  status     String    @default("pending")
  approvedBy String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  employee   Employee  @relation(fields: [employeeId], references: [id])
}

model LoginHistory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId String   @db.ObjectId
  ipAddress  String?
  device     String?
  browser    String?
  loginTime  DateTime @default(now())
  success    Boolean  @default(true)

  employee   Employee @relation(fields: [employeeId], references: [id])
}

model SuspiciousLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId  String   @db.ObjectId
  type        String
  description String
  ipAddress   String?
  createdAt   DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id])
}

model Department {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
}

model Role {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
}

model Startup {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  startupName  String
  founderName  String
  founderEmail String?
  founderPhone String?
  program      String    @default("Diksuchi")
  stage        String    @default("Idea")
  mentor       String?
  description  String?
  fundingStage String    @default("Bootstrapped")
  progress     Int       @default(0)
  status       String    @default("Active")
  website      String?
  logo         String?
  industry     String?
  teamSize     Int?
  location     String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Archive {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  sourceTable    String
  sourceId       String
  snapshot       Json
  archivedBy     String    @db.ObjectId
  archivedAt     DateTime  @default(now())
  retentionUntil DateTime?
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId    String   @db.ObjectId
  action     String
  resource   String
  resourceId String
  details    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
}
